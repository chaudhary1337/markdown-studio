{
  "name": "better-markdown",
  "displayName": "Better Markdown",
  "description": "Notion-like WYSIWYG markdown editor for VSCode",
  "version": "0.1.0",
  "publisher": "better-markdown",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "betterMarkdown.editor",
        "displayName": "Better Markdown",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "betterMarkdown.toggleEditor",
        "title": "Toggle Rich/Source Editor",
        "category": "Better Markdown",
        "icon": "$(notebook-render-output)"
      },
      {
        "command": "betterMarkdown.find",
        "title": "Find in Document",
        "category": "Better Markdown"
      }
    ],
    "keybindings": [
      {
        "command": "betterMarkdown.toggleEditor",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "resourceExtname == .md"
      },
      {
        "command": "betterMarkdown.find",
        "key": "ctrl+f",
        "mac": "cmd+f",
        "when": "activeCustomEditorId == betterMarkdown.editor"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "betterMarkdown.toggleEditor",
          "group": "navigation",
          "when": "resourceExtname == .md"
        }
      ]
    }
  },
  "scripts": {
    "test": "npx tsx scripts/test-roundtrip.ts",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package",
    "deploy": "bash scripts/deploy.sh",
    "vscode:prepublish": "node esbuild.js --production"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@tiptap/extension-code-block-lowlight": "^3.22.1",
    "@tiptap/extension-image": "^3.22.1",
    "@tiptap/extension-link": "^3.22.1",
    "@tiptap/extension-table": "^3.22.1",
    "@tiptap/extension-table-cell": "^3.22.1",
    "@tiptap/extension-table-header": "^3.22.1",
    "@tiptap/extension-table-row": "^3.22.1",
    "@tiptap/extension-task-item": "^3.22.1",
    "@tiptap/extension-task-list": "^3.22.1",
    "@tiptap/pm": "^3.22.1",
    "@tiptap/react": "^3.22.1",
    "@tiptap/starter-kit": "^3.22.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rehype-parse": "^9.0.1",
    "rehype-remark": "^10.0.1",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5"
  }
}
