{
  "name": "its-markdown-studio",
  "displayName": "Markdown Studio",
  "description": "Notion-like WYSIWYG markdown editor with rich diffs, tables, images, math, and more.",
  "version": "1.0.0",
  "publisher": "tanishq-chaudhary",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/chaudhary1337/better-markdown-issues"
  },
  "bugs": {
    "url": "https://github.com/chaudhary1337/better-markdown-issues/issues"
  },
  "homepage": "https://github.com/chaudhary1337/better-markdown-issues",
  "icon": "logo7.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Formatters",
    "Visualization"
  ],
  "keywords": [
    "markdown",
    "wysiwyg",
    "editor",
    "notion",
    "rich text",
    "rich diff",
    "diff",
    "md",
    "rich editor",
    "table",
    "math",
    "latex",
    "katex",
    "preview",
    "documentation",
    "notes",
    "note-taking",
    "gfm",
    "writing",
    "wiki",
    "notion-like",
    "rich text editor",
    "live preview",
    "knowledge base",
    "readme",
    "wysiwyg editor",
    "rich markdown",
    "github flavored markdown"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "betterMarkdown.editor",
        "displayName": "Better Markdown",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "betterMarkdown.toggleEditor",
        "title": "Toggle Rich/Source Editor",
        "category": "Better Markdown",
        "icon": "$(notebook-render-output)"
      },
      {
        "command": "betterMarkdown.find",
        "title": "Find in Document",
        "category": "Better Markdown"
      },
      {
        "command": "betterMarkdown.openDiff",
        "title": "Open Rich Diff",
        "category": "Better Markdown",
        "icon": "$(diff)"
      },
      {
        "command": "betterMarkdown.openInBrowser",
        "title": "Open in Browser",
        "category": "Better Markdown",
        "icon": "$(globe)"
      }
    ],
    "keybindings": [
      {
        "command": "betterMarkdown.toggleEditor",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "resourceExtname == .md"
      },
      {
        "command": "betterMarkdown.find",
        "key": "ctrl+f",
        "mac": "cmd+f",
        "when": "activeCustomEditorId == betterMarkdown.editor"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "betterMarkdown.openDiff",
          "when": "resourceExtname == .md || isInDiffEditor"
        }
      ],
      "editor/title": [
        {
          "command": "betterMarkdown.toggleEditor",
          "group": "navigation",
          "when": "resourceExtname == .md"
        },
        {
          "command": "betterMarkdown.openDiff",
          "group": "navigation",
          "when": "isInDiffEditor && resourceExtname == .md"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "betterMarkdown.openDiff",
          "group": "1_modification",
          "when": "scmProvider == git && resourceExtname == .md"
        }
      ]
    }
  },
  "scripts": {
    "test": "npx tsx scripts/test-conversions.ts && npx tsx scripts/test-roundtrip.ts",
    "test:conversions": "npx tsx scripts/test-conversions.ts",
    "test:roundtrip": "npx tsx scripts/test-roundtrip.ts",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "serve": "node esbuild.js && npx tsx server/index.ts",
    "package": "vsce package",
    "deploy": "bash scripts/deploy.sh",
    "vscode:prepublish": "node esbuild.js --production"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.80.0",
    "@types/ws": "^8.18.1",
    "@types/diff": "^7.0.2",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@tiptap/extension-code-block-lowlight": "^3.22.1",
    "@tiptap/extension-image": "^3.22.1",
    "@tiptap/extension-link": "^3.22.1",
    "@tiptap/extension-table": "^3.22.1",
    "@tiptap/extension-table-cell": "^3.22.1",
    "@tiptap/extension-table-header": "^3.22.1",
    "@tiptap/extension-table-row": "^3.22.1",
    "@tiptap/extension-task-item": "^3.22.1",
    "@tiptap/extension-task-list": "^3.22.1",
    "@tiptap/pm": "^3.22.1",
    "@tiptap/react": "^3.22.1",
    "@tiptap/starter-kit": "^3.22.1",
    "@tiptap/suggestion": "^3.22.1",
    "diff": "^8.0.4",
    "diff2html": "^3.4.56",
    "katex": "^0.16.45",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.7.0",
    "node-htmldiff": "^0.9.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rehype-parse": "^9.0.1",
    "rehype-remark": "^10.0.1",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "ws": "^8.20.0"
  }
}
